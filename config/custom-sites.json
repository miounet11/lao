      ],
      "example": "iatlas-browser site huggingface/models sentence-transformers",
      "args": [
        {
          "name": "query",
          "required": true,
          "description": "Search query"
        },
        {
          "name": "count",
          "required": false,
          "description": "Number of results (default 10, max 50)"
        }
      ],
      "file": "_hosted/huggingface/models.js",
      "source": "hosted-extension"
    },
    {
      "name": "maven/search",
      "platform": "maven",
      "command": "search",
