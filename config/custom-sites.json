          "description": "Stack Exchange site slug, default: stackoverflow"
        },
        {
          "name": "count",
          "required": false,
          "description": "Number of results (default 10, max 50)"
        }
      ],
      "file": "_hosted/stackexchange/search.js",
      "source": "hosted-extension"
    }
